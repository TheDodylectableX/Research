//   Purpose: Reverse engineering Tomb Raider: Angel of Darkness (Remastered)'s archives
//  Category: Archives
// File Mask: *.GMX
//  ID Bytes: 66 66 66 40
//   History: 
//---------------------------------------------------------------------------------------

typedef struct {
    float Version; // Why a float???? Bruh
    ushort fileCount <name="File Count">;
    ushort Unknown   <format=hex>;
} GMX_HEADER <read=Str("GMX Version %f | %u Files", this.Version, this.fileCount)>;

typedef struct {
    uint fileNameHash <name="File Name Hash", format=hex>;
    uint fileOffset   <name="File Offset", comment="Add 2048 bytes">;
    uint fileSize     <name="File Size">;
    
    local uint64 currentPosition <hidden=true> = FTell();
    FSeek(fileOffset + 2048);
    if (fileSize > 0) byte fileData[fileSize] <name="File Data">;
    FSeek(currentPosition);
} GMX_ENTRY <read=Str("File Name Hash: 0x%X | File Offset: %u | File Size: %u bytes", this.fileNameHash, this.fileOffset + 2048, this.fileSize)>;

//---------------------------------------------------------------------------------------

struct {
    GMX_HEADER Header;
    if (Header.fileCount > 0) GMX_ENTRY Entries[Header.fileCount] <optimize=false>;
} GMX <name="Tomb Raider: Angel of Darkness (Remastered) .GMX Archive">;

//---------------------------------------------------------------------------------------
